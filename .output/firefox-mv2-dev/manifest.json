{
  "manifest_version": 2,
  "name": "Eye Exercises Tool",
  "description": "Powerful extension for guided eye exercises to reduce eye strain and improve vision health.",
  "version": "1.0.1",
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "96": "icon/96.png",
    "128": "icon/128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "http://localhost/*"
  ],
  "options_page": "dashboard.html",
  "commands": {
    "wxt:reload-extension": {
      "description": "Reload the extension during development",
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "Eye Exercises Tool - Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-scripts/banner.js"
      ]
    }
  ],
  "content_security_policy": "script-src 'self' http://localhost:3000; object-src 'self';",
  "browser_action": {
    "default_icon": {
      "16": "icon/16.png",
      "32": "icon/32.png",
      "48": "icon/48.png",
      "96": "icon/96.png",
      "128": "icon/128.png"
    }
  }
}